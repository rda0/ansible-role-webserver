/var/log/nginx/*.log {
    daily
    missingok
    rotate 14
    compress
{% if not webserver_logrotate_nginx_date_extension %}
{# this appears to confuse logrotate sometimes when using dates #}
    delaycompress
{% endif %}
    ifempty
    create 0640 www-data adm
    sharedscripts
{% if webserver_logrotate_nginx_date_extension %}
    dateext
    dateformat .%Y-%m-%d
    extension .log
{% endif %}
    postrotate
        invoke-rc.d nginx rotate >/dev/null 2>&1
    endscript
}
